{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Start Jekyll",
			"type": "shell",
			"command": "bundle exec jekyll serve --livereload",
			"options": {
				"cwd": "${workspaceFolder}/exp/Jekyll"
			},
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "new"
			},
			"runOptions": {
				"runOn": "default"
			}
		}
	]
}
